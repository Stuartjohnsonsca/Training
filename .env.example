# Vercel Postgres — auto-injected when you connect a Postgres store in Vercel.
# Locally, paste the value from Vercel → Storage → your Postgres → .env.local tab.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ElevenLabs — get from elevenlabs.io
ELEVENLABS_API_KEY="..."
# Default voice ID. Find one at elevenlabs.io/voice-library, or override per-lesson later.
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"

# Shared password gate (anyone with this can use the trainer)
APP_PASSWORD="change-me"
# Separate, stronger password for the admin section (category management)
ADMIN_PASSWORD="change-me-too"

# Random 32-char string used to sign session cookies
SESSION_SECRET="change-this-to-a-32-plus-character-random-string"
