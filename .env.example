# Database — auto-injected by Vercel when you connect a Postgres store (e.g. Neon).
# Locally, paste from Vercel → Storage → your Postgres → .env.local tab.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Together AI (lesson generator + grader + feedback summary)
# Default model: meta-llama/Llama-3.3-70B-Instruct-Turbo (override with TOGETHER_MODEL).
TOGETHER_API_KEY="..."
# TOGETHER_MODEL="meta-llama/Llama-3.3-70B-Instruct-Turbo"

# ElevenLabs — get from elevenlabs.io
ELEVENLABS_API_KEY="..."
# Default voice ID. Find one at elevenlabs.io/voice-library, or override.
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"

# Microsoft Entra ID (Azure AD) — reuse the existing Acumon app registration.
# Add this redirect URI to that app: https://<your-vercel-domain>/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID="..."
AZURE_AD_CLIENT_SECRET="..."

# NextAuth signing secret. Any 32+ character random string.
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="change-this-to-a-32-plus-character-random-string"

# Sole admin email (user with rights to /admin). Anyone else with @acumon.com can use /learn but not /admin.
ADMIN_EMAIL="stuart@acumon.com"
