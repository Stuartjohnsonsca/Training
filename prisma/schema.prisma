generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Category {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  systemPrompt    String   @db.Text
  allowedWidgets  String[]
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lessons         Lesson[]
}

model Lesson {
  id              String    @id @default(cuid())
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  topic           String
  topicNormalized String
  title           String
  /// Built incrementally during generation. Always shape: {title, objectives, slides, quiz}. slides/quiz may be partial while status='generating'.
  content         Json
  /// Lower-cased concept tags extracted at generation time (e.g. ["depreciation", "straight-line", "frs 102"]).
  /// Used to find reusable slides/questions when generating a new related lesson.
  concepts        String[]  @default([])
  /// How many times this lesson has been used as reference material for a new lesson.
  reuseCount      Int       @default(0)
  /// 'generating' while chunked LLM calls are still running; 'ready' once complete; 'failed' on error.
  status          String    @default("ready")
  createdAt       DateTime  @default(now())
  attempts        Attempt[]

  @@index([categoryId, topicNormalized])
  @@index([categoryId, concepts])
}

/// Single-row branding/configuration table. Always read by id="default".
model Setting {
  id             String   @id @default("default")
  brandName      String   @default("Acumon Training")
  logoUrl        String?
  primaryColor   String   @default("#1d4ed8")
  footerText     String?
  updatedAt      DateTime @updatedAt
}

model Attempt {
  id          String    @id @default(cuid())
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  learner     String?
  answers     Json
  feedback    String?   @db.Text
  totalScore  Float
  maxScore    Float
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}
