generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Category {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  systemPrompt    String   @db.Text
  allowedWidgets  String[]
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lessons         Lesson[]
}

model Lesson {
  id              String    @id @default(cuid())
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  topic           String
  topicNormalized String
  title           String
  /// Built incrementally during generation. Always shape: {title, objectives, slides, quiz}. slides/quiz may be partial while status='generating'.
  content         Json
  /// Lower-cased concept tags extracted at generation time (e.g. ["depreciation", "straight-line", "frs 102"]).
  /// Used to find reusable slides/questions when generating a new related lesson.
  concepts        String[]  @default([])
  /// How many times this lesson has been used as reference material for a new lesson.
  reuseCount      Int       @default(0)
  /// 'generating' while chunked LLM calls are still running; 'ready' once complete; 'failed' on error.
  status          String    @default("ready")
  /// The refine-step chat history that produced this lesson. Stored so it can be replayed in CPD records.
  chatHistory     Json?
  createdAt       DateTime  @default(now())
  attempts        Attempt[]

  @@index([categoryId, topicNormalized])
  @@index([categoryId, concepts])
}

/// Single-row branding/configuration table. Always read by id="default".
model Setting {
  id             String   @id @default("default")
  brandName      String   @default("Acumon Training")
  logoUrl        String?
  primaryColor   String   @default("#1d4ed8")
  footerText     String?
  updatedAt      DateTime @updatedAt
}

model Attempt {
  id          String    @id @default(cuid())
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  learner     String?
  answers     Json
  feedback    String?   @db.Text
  totalScore  Float
  maxScore    Float
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  /// CPD record fields (filled in by /api/grade when the quiz is submitted)
  /// When the learner first opened the lesson player. Used to compute course duration.
  viewStartedAt DateTime?
  /// 1-2 sentence summary of what the course covered, AI-generated at completion.
  cpdSummary    String?  @db.Text
  /// Whether the learner / system flagged this course as Ethics-related.
  isEthics      Boolean  @default(false)
  /// IES 8 (IFAC International Education Standard 8) competence area number, 1-14.
  ies8Number    Int?
  /// Human-readable label for the IES 8 category.
  ies8Label     String?
  /// Free-text topic area (e.g. "Accounting — straight-line depreciation under FRS 102").
  topicArea     String?

  @@index([learner, completedAt])
}
