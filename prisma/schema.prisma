generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Category {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  systemPrompt    String   @db.Text
  allowedWidgets  String[]
  active          Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lessons         Lesson[]
}

model Lesson {
  id              String    @id @default(cuid())
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  topic           String
  topicNormalized String
  title           String
  /// Built incrementally during generation. Always shape: {title, objectives, slides, quiz}. slides/quiz may be partial while status='generating'.
  content         Json
  /// Lower-cased concept tags extracted at generation time (e.g. ["depreciation", "straight-line", "frs 102"]).
  /// Used to find reusable slides/questions when generating a new related lesson.
  concepts        String[]  @default([])
  /// How many times this lesson has been used as reference material for a new lesson.
  reuseCount      Int       @default(0)
  /// 'generating' while chunked LLM calls are still running; 'ready' once complete; 'failed' on error.
  status          String    @default("ready")
  /// The refine-step chat history that produced this lesson. Stored so it can be replayed in CPD records.
  chatHistory     Json?
  /// Total slide count planned for this lesson (default 8; scaled up by the planner when sources are attached).
  plannedSlideCount Int     @default(8)
  /// Total quiz question count planned for this lesson (default 7; scaled up when sources are attached).
  plannedQuizCount  Int     @default(7)
  /// Web-grounded sources retrieved at generation time (Tavily search against jurisdiction-whitelisted domains).
  /// Stored so the player can show learners the authoritative pages backing the lesson and the reviewer can cross-check.
  groundingPack    Json?
  /// Language the lesson content (slides, narration, quiz) was generated in. Independent of jurisdiction.
  outputLanguage   String   @default("English")
  createdAt       DateTime  @default(now())
  attempts        Attempt[]
  sources         LessonSource[]

  @@index([categoryId, topicNormalized])
  @@index([categoryId, concepts])
}

/// User-uploaded reference document (PDF, DOCX, PPTX, TXT) attached to a lesson.
/// Both the original file (Vercel Blob URL) and the extracted text are kept.
model LessonSource {
  id            String   @id @default(cuid())
  lessonId      String?
  lesson        Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  uploaderEmail String
  filename      String
  mimeType      String
  fileSizeBytes Int
  /// Public URL of the original file in Vercel Blob storage.
  blobUrl       String
  /// Plain-text content extracted server-side at upload time. Used as source material when generating the lesson.
  extractedText String   @db.Text
  /// Approximate token count of extractedText (chars/4) so we can size up planning calls.
  approxTokens  Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([lessonId])
  @@index([uploaderEmail])
}

/// Single-row branding/configuration table. Always read by id="default".
model Setting {
  id             String   @id @default("default")
  brandName      String   @default("Acumon Training")
  logoUrl        String?
  primaryColor   String   @default("#1d4ed8")
  footerText     String?
  updatedAt      DateTime @updatedAt
}

model Attempt {
  id          String    @id @default(cuid())
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  learner     String?
  answers     Json
  feedback    String?   @db.Text
  totalScore  Float
  maxScore    Float
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  /// CPD record fields (filled in by /api/grade when the quiz is submitted)
  /// When the learner first opened the lesson player. Used to compute course duration.
  viewStartedAt DateTime?
  /// 1-2 sentence summary of what the course covered, AI-generated at completion.
  cpdSummary    String?  @db.Text
  /// Whether the learner / system flagged this course as Ethics-related.
  isEthics      Boolean  @default(false)
  /// IES 8 (IFAC International Education Standard 8) competence area number, 1-14.
  ies8Number    Int?
  /// Human-readable label for the IES 8 category.
  ies8Label     String?
  /// Free-text topic area (e.g. "Accounting — straight-line depreciation under FRS 102").
  topicArea     String?

  /// CPD activity category from the regulator's prescribed list (E-learning, Reading & watching, etc.).
  activityCategory String?
  /// Structured CPD (formal, planned, with intended outcomes) vs unstructured (ad hoc reading etc.).
  /// AI-generated training defaults to true.
  isStructured  Boolean   @default(true)
  /// Learner-supplied reflection: why they chose this piece of CPD.
  whyUndertaken String?   @db.Text
  /// The intended learning outcomes — pre-filled from the lesson's objectives, learner can edit.
  intendedLearningOutcomes String? @db.Text
  /// Learner-supplied reflection: what they actually took away.
  learnedFromExercise String? @db.Text
  /// Did the lesson achieve its stated objectives (per the learner)?
  objectivesMet Boolean?

  @@index([learner, completedAt])
}
